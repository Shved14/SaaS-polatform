DATABASE_URL="postgresql://user:password@localhost:5432/saas_platform"
NEXTAUTH_URL="https://your-domain.com"
AUTH_SECRET="your_auth_secret_at_least_16_chars"

# For production deployment
NODE_ENV="production"
COOKIE_DOMAIN=".your-domain.com"  # Change to your domain

RESEND_API_KEY="your_resend_api_key"
RESEND_FROM="TaskFlow <onboarding@resend.dev>"

AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
