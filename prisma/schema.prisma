generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Пользователь SaaS-системы (password опционален для OAuth)
model User {
  id              String                @id @default(cuid())
  email           String?               @unique
  password        String?
  name            String?
  avatar          String?
  emailVerified   DateTime?
  createdAt       DateTime              @default(now())
  image           String?
  telegramId      String?               @unique
  plan            String                @default("FREE")
  theme           String?
  proUntil        DateTime?
  accounts        Account[]              @relation("UserAccounts")
  notifications   Notification[]         @relation("UserNotifications")
  notificationSettings NotificationSettings? @relation("UserNotificationSettings")
  sessions        Session[]              @relation("UserSessions")
  tasksAssigned   Task[]                @relation("TaskAssignee")
  activities      Activity[]            @relation("UserActivities")
  boardsOwned    Workspace[]            @relation("WorkspaceOwner")
  sentInvitations WorkspaceInvitation[] @relation("UserSentInvitations")
  memberships     WorkspaceMember[]     @relation("UserWorkspaceMemberships")
  taskComments    TaskComment[]         @relation("UserTaskComments")
  taskActivities  TaskActivity[]        @relation("UserTaskActivities")

  @@index([email])
  @@index([telegramId])
}

/// OAuth/Linked accounts (NextAuth)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation("UserAccounts", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

/// Сессии NextAuth (при использовании database strategy)
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation("UserSessions", fields: [userId], references: [id], onDelete: Cascade)
}

/// Токены верификации NextAuth (magic link и т.д.)
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// Рабочее пространство (workspace / организация)
model Workspace {
  id          String                @id @default(cuid())
  name        String
  ownerId     String
  createdAt   DateTime              @default(now())
  boards      Board[]
  invites     InviteLink[]
  integrations WorkspaceIntegration[] @relation("WorkspaceIntegrations")
  owner       User                  @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  invitations WorkspaceInvitation[]
  members     WorkspaceMember[]

  @@index([ownerId])
}

/// Участники рабочего пространства
model WorkspaceMember {
  id          String        @id @default(cuid())
  userId      String
  workspaceId String
  role        WorkspaceRole @default(MEMBER)
  user        User          @relation("UserWorkspaceMemberships", fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

/// Доска (board) внутри рабочего пространства
model Board {
  id          String    @id @default(cuid())
  name        String
  workspaceId String
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks       Task[]

  @@index([workspaceId])
}

/// Задача на доске
model Task {
  id              String           @id @default(cuid())
  title           String
  description     String?
  status          TaskStatus       @default(TODO)
  priority        TaskPriority     @default(MEDIUM)
  deadline        DateTime?
  assigneeId      String?
  boardId         String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  taskSubtasks    Subtask[]        @relation("TaskSubtasks")
  assignee        User?            @relation("TaskAssignee", fields: [assigneeId], references: [id])
  board           Board            @relation(fields: [boardId], references: [id])
  taskActivities  TaskActivity[]   @relation("TaskActivities")
  taskAttachments TaskAttachment[] @relation("TaskAttachments")
  taskComments    TaskComment[]    @relation("TaskComments")

  @@index([boardId])
  @@index([assigneeId])
  @@index([status])
  @@index([priority])
}

/// Вложения к задаче
model TaskAttachment {
  id          String   @id @default(cuid())
  taskId      String
  filename    String
  originalName String
  size        Int
  contentType String
  path        String
  createdAt   DateTime @default(now())
  task         Task     @relation("TaskAttachments", fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

/// Комментарии к задаче
model TaskComment {
  id        String   @id @default(cuid())
  content   String
  taskId    String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation("UserTaskComments", fields: [authorId], references: [id], onDelete: Cascade)
  task      Task     @relation("TaskComments", fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([authorId])
  @@index([createdAt])
}

/// Подзадача (чеклист)
model Subtask {
  id        String   @id @default(cuid())
  title     String
  completed Boolean  @default(false)
  taskId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  task      Task     @relation("TaskSubtasks", fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([completed])
}

/// История изменений задачи
model TaskActivity {
  id        String           @id @default(cuid())
  taskId    String
  userId    String
  action    TaskActivityType
  oldValue  String?
  newValue  String?
  metadata  String?
  createdAt DateTime         @default(now())
  task      Task             @relation("TaskActivities", fields: [taskId], references: [id], onDelete: Cascade)
  user      User             @relation("UserTaskActivities", fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
  @@index([createdAt])
}

/// Уведомление для пользователя (инбокс)
model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  data      Json?    // Дополнительные данные для навигации
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

/// Настройки уведомлений пользователя
model NotificationSettings {
  id                   String  @id @default(cuid())
  userId               String  @unique
  emailEnabled         Boolean @default(true)
  pushEnabled          Boolean @default(true)
  taskAssigned         Boolean @default(true)
  taskComment         Boolean @default(true)
  taskDeadlineToday   Boolean @default(true)
  taskOverdue         Boolean @default(true)
  workspaceInvitation Boolean @default(true)
  taskCreated         Boolean @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user               User    @relation("UserNotificationSettings", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Интеграции workspace
model WorkspaceIntegration {
  id         String   @id @default(cuid())
  workspaceId String
  type       String   // "slack", "discord", etc.
  webhookUrl String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  workspace  Workspace @relation("WorkspaceIntegrations", fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, type])
  @@index([workspaceId])
}

/// История действий (Activity Log)
model Activity {
  id          String   @id @default(cuid())
  userId       String
  action       String   // "created_task", "updated_task", "deleted_task", "comment", "status_change", etc.
  entityId     String   // ID связанной сущности (задачи, доски, etc.)
  entityType   String   // "task", "board", "workspace", "comment", etc.
  details      Json?    // Детали действия (старые/новые значения, текст комментария и т.д.)
  metadata     Json?    // Дополнительные метаданные (IP адрес, user agent и т.д.)
  createdAt    DateTime @default(now())
  user        User     @relation("UserActivities", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([entityId])
  @@index([entityType])
  @@index([action])
}

/// Пригласительная ссылка в воркспейс
model InviteLink {
  id          String    @id @default(cuid())
  workspaceId String
  token       String    @unique
  expiresAt   DateTime
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

/// Email invitation for workspace members
model WorkspaceInvitation {
  id          String    @id @default(cuid())
  email       String
  workspaceId String
  inviterId   String
  status      String    @default("pending") // "pending", "accepted", "expired"
  token       String    @unique @default(cuid()) // Используем cuid вместо случайной строки
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  expiresAt   DateTime  @default(dbgenerated("(now() + interval '7 days')")) // Автоматический расчет срока истечения
  inviter     User      @relation("UserSentInvitations", fields: [inviterId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([email, workspaceId])
  @@index([token])
}

/// Верификационный код (например, для подтверждения email или reset password)
model VerificationCode {
  id             String   @id @default(cuid())
  email          String
  code           String
  expiresAt      DateTime
  hashedPassword String?
  name           String?

  @@unique([email, code])
  @@index([email])
  @@index([expiresAt])
}

/// Статус задачи
enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

/// Приоритет задачи
enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

/// Тип активности в задаче
enum TaskActivityType {
  CREATED
  UPDATED
  STATUS_CHANGED
  ASSIGNEE_CHANGED
  PRIORITY_CHANGED
  DEADLINE_CHANGED
  COMMENT_ADDED
  SUBTASK_ADDED
  SUBTASK_COMPLETED
  SUBTASK_UNCOMPLETED
}

/// Роль участника рабочего пространства
enum WorkspaceRole {
  OWNER
  MEMBER
}
