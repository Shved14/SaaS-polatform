generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Пользователь SaaS-системы (password опционален для OAuth)
model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  password      String? // хэш bcrypt; null для OAuth
  name          String?
  avatar        String?
  image         String? // дубликат для NextAuth (image = avatar)
  emailVerified DateTime?
  telegramId    String?   @unique
  plan          String    @default("FREE") // FREE | PRO
  theme         String? // JSON: { primary, background, accent } for dashboard
  proUntil      DateTime?
  createdAt     DateTime  @default(now())

  accounts        Account[]
  sessions        Session[]
  workspacesOwned Workspace[]
  memberships     WorkspaceMember[]
  tasksAssigned   Task[]            @relation("TaskAssignee")
  comments        TaskComment[]
  activities      TaskActivity[]
  sentInvitations WorkspaceInvitation[]
  notifications   Notification[]

  @@index([email])
  @@index([telegramId])
}

/// OAuth/Linked accounts (NextAuth)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

/// Сессии NextAuth (при использовании database strategy)
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Токены верификации NextAuth (magic link и т.д.)
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// Рабочее пространство (workspace / организация)
model Workspace {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime @default(now())

  owner   User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members WorkspaceMember[]
  boards  Board[]
  invites InviteLink[]
  invitations WorkspaceInvitation[]

  @@index([ownerId])
}

/// Участники рабочего пространства
model WorkspaceMember {
  id          String        @id @default(cuid())
  userId      String
  workspaceId String
  role        WorkspaceRole @default(MEMBER)

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

/// Доска (board) внутри рабочего пространства
model Board {
  id          String   @id @default(cuid())
  name        String
  workspaceId String
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks     Task[]

  @@index([workspaceId])
}

/// Задача на доске
model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  deadline    DateTime?
  assigneeId  String?
  boardId     String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  assignee User?         @relation("TaskAssignee", fields: [assigneeId], references: [id])
  board    Board         @relation(fields: [boardId], references: [id], onDelete: Cascade)
  comments TaskComment[]
  subtasks Subtask[]
  activities TaskActivity[]

  @@index([boardId])
  @@index([assigneeId])
  @@index([status])
  @@index([priority])
  @@index([deadline])
}

/// Комментарий к задаче
model TaskComment {
  id        String   @id @default(cuid())
  content   String
  taskId    String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([authorId])
  @@index([createdAt])
}

/// Подзадача (чеклист)
model Subtask {
  id        String   @id @default(cuid())
  title     String
  completed Boolean  @default(false)
  taskId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([completed])
}

/// История изменений задачи
model TaskActivity {
  id          String       @id @default(cuid())
  taskId      String
  userId      String
  action      TaskActivityType
  oldValue    String?      // JSON-serialized old value
  newValue    String?      // JSON-serialized new value
  metadata    String?      // JSON-serialized additional metadata
  createdAt   DateTime     @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
  @@index([createdAt])
}

/// Уведомление для пользователя (инбокс)
model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  data      Json
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

/// Пригласительная ссылка в воркспейс
model InviteLink {
  id          String   @id @default(cuid())
  workspaceId String
  token       String   @unique
  expiresAt   DateTime

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

/// Email invitation for workspace members
model WorkspaceInvitation {
  id          String   @id @default(cuid())
  email       String
  workspaceId String
  inviterId   String
  status      String   @default("pending") // pending / accepted / declined
  token       String   @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  inviter   User      @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([email, workspaceId])
  @@index([status])
}

/// Верификационный код (например, для подтверждения email или reset password)
model VerificationCode {
  id             String   @id @default(cuid())
  email          String
  code           String
  expiresAt      DateTime
  hashedPassword String?
  name           String?

  @@unique([email, code])
  @@index([email])
  @@index([expiresAt])
}

/// Статус задачи
enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

/// Приоритет задачи
enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

/// Тип активности в задаче
enum TaskActivityType {
  CREATED
  UPDATED
  STATUS_CHANGED
  ASSIGNEE_CHANGED
  PRIORITY_CHANGED
  DEADLINE_CHANGED
  COMMENT_ADDED
  SUBTASK_ADDED
  SUBTASK_COMPLETED
  SUBTASK_UNCOMPLETED
}

/// Роль участника рабочего пространства
enum WorkspaceRole {
  OWNER
  MEMBER
}
